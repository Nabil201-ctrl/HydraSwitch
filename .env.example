# HydraSwitch Environment
PORT=3000

# === Paystack Integration ===
# Get your test secret key from https://dashboard.paystack.com/#/settings/developer
# (Use the TEST secret key that starts with sk_test_...)
PAYSTACK_SECRET_KEY=sk_test_your_test_secret_key_here

# Which provider to use by default when none is specified on create
# "paystack" or "mock"
DEFAULT_PROVIDER=paystack
